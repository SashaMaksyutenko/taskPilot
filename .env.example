# Template for docker-compose variable substitution.
# Copy to ".env" (repo root) and fill in real values. The real .env is gitignored.
# These feed the "api" service in docker-compose.yml.

# JWT signing key — generate a long random base64 string.
JWT_KEY=GENERATE_A_LONG_RANDOM_BASE64_KEY

# Initial admin account (created/promoted on startup).
ADMIN_EMAIL=admin@taskpilot.local
ADMIN_PASSWORD=CHANGE_ME_StrongPass1
