# Template for backend secrets. Copy to ".env" and fill in real values.
# The real .env is gitignored and must NEVER be committed.
# .NET maps the "__" separator to the ":" configuration hierarchy.

# --- PostgreSQL ---
# Locally: the key-value form below. When deploying to a managed host (Railway, Render,
# Heroku) you can instead set a single DATABASE_URL like
#   postgresql://user:password@host:5432/dbname
# and the app converts it automatically — no need to hand-build the string above.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=taskpilot;Username=postgres;Password=YOUR_PASSWORD

# --- CORS: browser origins allowed to call this API (comma-separated) ---
# The Vite dev server (http://localhost:5173) is ALWAYS allowed, so this can stay empty
# for local work. In production set it to the deployed frontend, e.g.
#   Cors__AllowedOrigins=https://taskpilot.vercel.app
# Without this the browser blocks every request from the deployed site.
Cors__AllowedOrigins=

# --- Redis (optional). Empty = in-memory cache; e.g. localhost:6379 to enable Redis. ---
Redis__Connection=

# --- RabbitMQ (optional). Empty = notifications delivered inline; set to offload
# side-channel delivery to a MassTransit consumer. e.g. amqp://guest:guest@localhost:5672 ---
RabbitMq__Connection=

# --- Telegram bot (optional; from @BotFather). Empty token = bot disabled. ---
Telegram__BotToken=
Telegram__BotUsername=

# --- Viber bot (optional; from Viber admin panel). Empty token = disabled.
# Linking needs a public webhook set via Viber's set_webhook to /api/viber/webhook. ---
Viber__AuthToken=
Viber__BotName=TaskPilot

# --- Web Push / VAPID (optional). Generate a key pair once; empty = push disabled.
# The API logs a fresh pair at startup when these are empty. ---
Vapid__Subject=mailto:admin@taskpilot.local
Vapid__PublicKey=
Vapid__PrivateKey=

# --- JWT ---
Jwt__Key=GENERATE_A_LONG_RANDOM_BASE64_KEY
Jwt__Issuer=Taskpilot.API
Jwt__Audience=Taskpilot.Client
# Optional token lifetimes (defaults: 15 minutes / 7 days).
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# --- Security ---
# Optional IP allowlist for the admin API (/api/admin). Comma-separated IPs and/or CIDR
# ranges, e.g. "203.0.113.5, 10.0.0.0/8". Leave empty to allow admin access from anywhere
# (it is always still behind an Admin-role check). Behind a proxy this uses X-Forwarded-For.
#
# GOTCHA: a browser on the same machine usually connects over IPv6, so the server sees ::1
# (NOT 127.0.0.1) and "127.0.0.1" alone would lock you out. List both loopback forms:
#   Security__AdminIpAllowlist=127.0.0.1, ::1
# Verify you can still reach /api/admin/stats right after setting this.
Security__AdminIpAllowlist=

# --- Initial admin (created/promoted on startup) ---
Admin__Email=admin@taskpilot.local
Admin__Password=CHANGE_ME_StrongPass1
Admin__Name=Administrator

# --- Stripe payments (optional; from Stripe dashboard). Empty key = payments disabled. ---
Stripe__SecretKey=
Stripe__Currency=usd
# Webhook signing secret (whsec_…) from a Stripe webhook endpoint (event: checkout.session.completed).
# Empty = webhook endpoint disabled. URL to register: https://<host>/api/marketplace/stripe/webhook
Stripe__WebhookSecret=

# --- AI assistant (optional). OpenAI-compatible. Empty key = assistant disabled.
# Default is OpenAI; for a free option use Groq (https://console.groq.com):
#   OpenAi__BaseUrl=https://api.groq.com/openai/v1
#   OpenAi__Model=llama-3.3-70b-versatile ---
OpenAi__ApiKey=
OpenAi__Model=gpt-4o-mini
OpenAi__BaseUrl=https://api.openai.com/v1

# --- GIFs in chat (optional) ---
# Empty ApiKey disables the GIF button. Provider is "Giphy" (default) or "Tenor".
#   Giphy key:  https://developers.giphy.com  (free)
#   Tenor key:  https://developers.google.com/tenor  (free)
Gif__Provider=Giphy
Gif__ApiKey=
Gif__Rating=pg-13

# --- Google OAuth (optional; from Google Cloud Console) ---
GoogleOAuth__ClientId=
GoogleOAuth__ClientSecret=
GoogleOAuth__RedirectUri=http://localhost:5173/auth/google/callback

# --- GitHub OAuth (optional; from GitHub Developer settings) ---
GitHubOAuth__ClientId=
GitHubOAuth__ClientSecret=
GitHubOAuth__RedirectUri=http://localhost:5173/auth/github/callback

# --- LinkedIn OAuth (optional; from LinkedIn developer app, "Sign In with LinkedIn using OpenID Connect") ---
LinkedInOAuth__ClientId=
LinkedInOAuth__ClientSecret=
LinkedInOAuth__RedirectUri=http://localhost:5173/auth/linkedin/callback

# --- Email (optional). Prefer SMTP; SendGrid API is the fallback. ---
Email__FromEmail=no-reply@taskpilot.local
Email__FromName=TaskPilot
Email__FrontendBaseUrl=http://localhost:5173

# SMTP (e.g. Gmail: smtp.gmail.com / 587, user = your@gmail.com, password = app password)
Email__SmtpHost=
Email__SmtpPort=587
Email__SmtpUser=
Email__SmtpPassword=
Email__SmtpUseSsl=true

# SendGrid API (used only when SmtpHost is empty)
Email__ApiKey=

# --- File storage (S3-compatible) -------------------------------------------
# Leave empty and uploads go to the local disk (fine for development).
# REQUIRED FOR DEPLOYMENT: hosting platforms give you an ephemeral filesystem,
# so anything written to disk is lost on the next restart.
# Works with Cloudflare R2 (free tier), Backblaze B2, MinIO or AWS S3.
#
# Cloudflare R2 example:
#   Storage__ServiceUrl=https://<account-id>.r2.cloudflarestorage.com
#   Storage__Region=auto
Storage__Bucket=
Storage__AccessKey=
Storage__SecretKey=
Storage__ServiceUrl=
Storage__Region=auto
