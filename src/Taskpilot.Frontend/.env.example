# Шаблон змінних середовища для фронтенду (Vite).
# Скопіюйте цей файл у .env і підставте свої значення.
# Реальний .env у .gitignore — у git НЕ потрапляє.
# Vite віддає на клієнт ЛИШЕ змінні з префіксом VITE_ (інші лишаються приватними).
# ВАЖЛИВО: усе з префіксом VITE_ потрапляє у браузер — НЕ клади сюди секретні ключі!

# Адреса бекенду API (порт із launchSettings.json профілю http)
VITE_API_URL=http://localhost:5025

# Публічний (publishable) ключ Stripe — він і має бути публічним
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Google OAuth client id (публічний). Порожній = кнопка "Продовжити через Google" прихована.
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth client id (публічний). Порожній = кнопка "Продовжити через GitHub" прихована.
VITE_GITHUB_CLIENT_ID=
